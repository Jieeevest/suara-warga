# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Super admin credentials (defaults: superadmin/superadmin)
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=superadmin

# Session secret for cookie signing
AUTH_SECRET=replace_this_with_a_long_random_secret

# SMTP config for resident access email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM="Sura Warga <your_gmail_address@gmail.com>"

# Optional RSA keys for vote encryption.
# If omitted, the app will generate a temporary key pair at runtime.
# For production or stable testing, generate and store both keys in .env.local.
VOTING_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_PUBLIC_KEY_HERE\n-----END PUBLIC KEY-----"
VOTING_RSA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"
